# ── Backend environment variables ───────────────────────────────────────────
# Copy this file to .env for local dev.
# In Render dashboard → Environment, add all of these.

NODE_ENV=production
PORT=5000

# MongoDB Atlas connection string (free M0 cluster)
# Get from: atlas.mongodb.com → your cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/classyshop?retryWrites=true&w=majority

# Strong random string for JWT signing (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_with_a_long_random_secret

# Your Anthropic API key (for AI chatbot / blog generation)
ANTHROPIC_API_KEY=sk-ant-...

# Your Vercel frontend URL (no trailing slash) — added after you deploy frontend
FRONTEND_URL=https://classyshop.vercel.app

# Your custom domain once pointed (no trailing slash)
CUSTOM_DOMAIN_URL=https://classyshop.pk

# Public site URL used in SEO/sitemap
SITE_URL=https://classyshop.pk
