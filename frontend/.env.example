# ── Frontend environment variables ──────────────────────────────────────────
# Copy this file to .env.local for local dev (leave REACT_APP_API_URL empty).
# In Vercel dashboard → Settings → Environment Variables, add these.

# Leave empty in development (CRA proxy handles /api/... → localhost:5000).
# In production, set this to your Render backend URL:
#   e.g. https://classyshop-api.onrender.com
REACT_APP_API_URL=
